# Copy to `.env` and fill in what you want. Everything is optional —
# the stack runs fully without any of these set.

# Minimum alert level (Wazuh scale 0-15) that triggers a notification
ALERT_LEVEL=10

# --- Dashboard access control (optional) ---
# Set BOTH to require HTTP Basic auth before the dashboard/API load.
# Leave empty for an open local demo. Always set these for anything reachable
# beyond localhost.
DASH_USER=
DASH_PASS=

# --- Data retention (optional) ---
# Delete events older than this many days (0 = keep everything). Prevents
# unbounded growth on a long-lived internet-facing sensor.
RETENTION_DAYS=0

# --- Threat intel (optional) ---
# AbuseIPDB API key adds reputation scores + Tor flags to attacker IPs
ABUSEIPDB_KEY=

# --- Telegram alerts (optional) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email alerts (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_TO=

# How often to auto-write an HTML threat report (seconds)
REPORT_EVERY_SECONDS=86400
