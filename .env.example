# Copy to `.env` and fill in what you want. Everything is optional —
# the stack runs fully without any of these set.

# Minimum alert level (Wazuh scale 0-15) that triggers a notification
ALERT_LEVEL=10

# --- Threat intel (optional) ---
# AbuseIPDB API key adds reputation scores + Tor flags to attacker IPs
ABUSEIPDB_KEY=

# --- Telegram alerts (optional) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email alerts (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_TO=

# How often to auto-write an HTML threat report (seconds)
REPORT_EVERY_SECONDS=86400
